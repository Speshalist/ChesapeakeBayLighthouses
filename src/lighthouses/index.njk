<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Lighthouse Directory</title>
    <link rel="stylesheet" href="{{ lighthouses.repoBasePath }}assets/css/site.css" />
  </head>
  <body>
    <header class="site-header">
      <h1>Lighthouse Directory</h1>
      <nav>
        <a href="{{ lighthouses.repoBasePath }}">Map</a>
        <a href="{{ lighthouses.repoBasePath }}lighthouses/">Directory</a>
      </nav>
    </header>

    <main class="content">
      <section class="directory-toolbar" aria-label="Sort lighthouses">
        <label for="sort-by">Sort by</label>
        <select id="sort-by">
          <option value="name">Name</option>
          <option value="state">State</option>
          <option value="status">Status</option>
          <option value="year_built">Year built</option>
          <option value="type">Type</option>
        </select>

        <button id="sort-dir" type="button" class="sort-dir" aria-pressed="false">
          Ascending
        </button>
      </section>

      <table class="table">
        <thead>
          <tr>
            <th scope="col" data-sort-key="name">Name</th>
            <th scope="col" data-sort-key="state">State</th>
            <th scope="col" data-sort-key="status">Status</th>
            <th scope="col" data-sort-key="year_built">Year built</th>
            <th scope="col" data-sort-key="type">Type</th>
          </tr>
        </thead>
        <tbody id="directory-rows">
          {% for lh in lighthouses.items %}
          <tr>
            <td data-sort-value="{{ lh.name | lower }}">
              <a href="{{ lighthouses.repoBasePath }}lighthouses/{{ lh.id }}/">{{ lh.name }}</a>
            </td>
            <td data-sort-value="{{ (lh.state or "") | lower }}">{{ lh.state or "" }}</td>
            <td data-sort-value="{{ (lh.status or "") | lower }}">{{ lh.status }}</td>
            <td data-sort-value="{{ lh.year_built or "" }}">{{ lh.year_built or "" }}</td>
            <td data-sort-value="{{ (lh.type or "") | lower }}">{{ lh.type }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </main>

    <script>
      (function () {
        const tbody = document.getElementById("directory-rows");
        const sortBy = document.getElementById("sort-by");
        const sortDirButton = document.getElementById("sort-dir");
        const headers = Array.from(document.querySelectorAll("th[data-sort-key]"));
        if (!tbody || !sortBy || !sortDirButton || !headers.length) return;

        let ascending = true;

        function columnIndexFromKey(key) {
          return ["name", "state", "status", "year_built", "type"].indexOf(key);
        }

        function valueFor(row, colIndex, key) {
          const cell = row.children[colIndex];
          const raw = String(cell?.dataset.sortValue ?? cell?.textContent ?? "").trim();
          if (key === "year_built") {
            const n = Number(raw);
            return Number.isFinite(n) ? n : -Infinity;
          }
          return raw.toLowerCase();
        }

        function updateHeaderState(key) {
          for (const th of headers) {
            const active = th.dataset.sortKey === key;
            th.classList.toggle("is-active-sort", active);
            const dir = ascending ? "ascending" : "descending";
            th.setAttribute("aria-sort", active ? dir : "none");
          }
        }

        function sortRows() {
          const key = sortBy.value;
          const colIndex = columnIndexFromKey(key);
          if (colIndex < 0) return;

          const rows = Array.from(tbody.querySelectorAll("tr"));
          rows.sort((a, b) => {
            const av = valueFor(a, colIndex, key);
            const bv = valueFor(b, colIndex, key);
            if (typeof av === "number" && typeof bv === "number") {
              return ascending ? av - bv : bv - av;
            }
            return ascending
              ? String(av).localeCompare(String(bv))
              : String(bv).localeCompare(String(av));
          });

          const frag = document.createDocumentFragment();
          for (const row of rows) frag.appendChild(row);
          tbody.appendChild(frag);

          sortDirButton.textContent = ascending ? "Ascending" : "Descending";
          sortDirButton.setAttribute("aria-pressed", String(!ascending));
          updateHeaderState(key);
        }

        sortBy.addEventListener("change", sortRows);
        sortDirButton.addEventListener("click", () => {
          ascending = !ascending;
          sortRows();
        });

        for (const th of headers) {
          th.addEventListener("click", () => {
            const key = th.dataset.sortKey;
            if (!key) return;
            if (sortBy.value === key) ascending = !ascending;
            else {
              sortBy.value = key;
              ascending = true;
            }
            sortRows();
          });
        }

        sortRows();
      })();
    </script>
  </body>
</html>
