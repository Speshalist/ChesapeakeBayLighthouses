<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Chesapeake Bay Lighthouses</title>

    <link rel="stylesheet" href="{{ lighthouses.repoBasePath }}assets/css/site.css" />
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""
    />
  </head>
  <body>
    <header class="site-header">
      <h1>Chesapeake Bay Lighthouses</h1>
      <nav>
        <a href="{{ lighthouses.repoBasePath }}">Map</a>
        <a href="{{ lighthouses.repoBasePath }}lighthouses/">Directory</a>
      </nav>
    </header>

    <main class="layout">
      <section class="panel">
        <h2>Map</h2>

        <fieldset class="control-group" id="basemap-controls">
          <legend>Basemap</legend>
          <div class="segmented-control" role="radiogroup" aria-label="Choose basemap">
            <label class="segment-option">
              <input type="radio" name="basemap" value="osm" checked />
              <span>Street</span>
            </label>
            <label class="segment-option">
              <input type="radio" name="basemap" value="water" />
              <span>Water Focus</span>
            </label>
          </div>
        </fieldset>

        <fieldset class="control-group" id="symbology-controls">
          <legend>Color by</legend>
          <div class="segmented-control" role="radiogroup" aria-label="Choose map symbology">
            <label class="segment-option">
              <input type="radio" name="symbology" value="status" checked />
              <span>Status</span>
            </label>
            <label class="segment-option">
              <input type="radio" name="symbology" value="type" />
              <span>Type</span>
            </label>
            <label class="segment-option">
              <input type="radio" name="symbology" value="year_built" />
              <span>Year Built</span>
            </label>
          </div>
        </fieldset>

        <p class="note">
          Destroyed lighthouses are shown by default with distinct styling.
        </p>

        <section class="timeline" aria-labelledby="timeline-heading">
          <h3 id="timeline-heading">Build Timeline</h3>
          <div class="timeline-controls">
            <button type="button" id="timeline-play" class="timeline-button">
              Play Timelapse
            </button>
            <button type="button" id="timeline-reset" class="timeline-button timeline-button-secondary">
              Show All
            </button>
          </div>
          <label for="timeline-year" class="timeline-label">Show lighthouses built by year:</label>
          <input
            id="timeline-year"
            type="range"
            min="1800"
            max="2000"
            step="1"
            value="2000"
            aria-describedby="timeline-current-year timeline-summary"
          />
          <div id="timeline-event-track" class="timeline-event-track" aria-hidden="true"></div>
          <p id="timeline-current-year" class="timeline-current-year">Year: --</p>
          <p id="timeline-event" class="timeline-event">Historical context: --</p>
          <p id="timeline-summary" class="note">Loading timeline data...</p>
        </section>

        <section id="legend" class="legend" aria-live="polite"></section>
      </section>

      <section class="map-wrap">
        <div id="map"></div>
      </section>
    </main>

    <script
      src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
      crossorigin=""
    ></script>
    <script>
      window.__REPO_BASE__ = "{{ lighthouses.repoBasePath }}";
    </script>
    <script src="{{ lighthouses.repoBasePath }}assets/js/map.js"></script>
  </body>
</html>
